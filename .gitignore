*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.tlog
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc
*.binlog

# Unity-style .meta note:
# Ignore for normal CS2 mod repos. If this becomes a real Unity project,
# remove this line because Unity .meta files should be tracked.
*.meta

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# Visual Studio profiler / tracing
*.psess
*.vsp
*.vspx
*.sap
*.e2e

# Local History for Visual Studio
.localhistory/
.vshistory/

# =========================
# Rider / ReSharper / JetBrains
# =========================
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
*.sln.iml
*.sln.DotSettings
.idea/

# =========================
# VS Code
# Keep shared workspace config files if you add them intentionally.
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# =========================
# .NET / NuGet
# =========================
project.lock.json
project.fragment.lock.json
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# =========================
# Publish / packaging
# =========================
publish/
*.[Pp]ublish.xml
*.azurePubxml

# Keep .pubxml trackable for CS2 / Paradox publish profiles.
# Do not commit .pubxml files if they contain secrets.
# *.pubxml

*.publishproj
*.publishsettings
PublishScripts/

# Windows app / installer outputs
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
*.appxbundle
*.appxupload
*.cab
*.msi
*.msix
*.msm
*.msp

# =========================
# Test / coverage / analyzer outputs
# =========================
BenchmarkDotNet.Artifacts/
StyleCopReport.xml
*.dotCover
.axoCover/*
!.axoCover/settings.json
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml
OpenCover/
FakesAssemblies/

# =========================
# Node / web tooling
# =========================
node_modules/
.ntvs_analysis.dat
.sass-cache/

# =========================
# Python
# =========================
__pycache__/
*.pyc

# =========================
# Secrets / local environment files
# =========================
.env
.env.*
!.env.example

